<view wx:if="{{a}}" class="page data-v-acf502d9"><swiper wx:if="{{b}}" class="img-swiper data-v-acf502d9" indicator-dots circular><swiper-item wx:for="{{c}}" wx:for-item="url" wx:key="b" class="data-v-acf502d9"><image src="{{url.a}}" mode="aspectFill" class="swiper-img data-v-acf502d9"></image></swiper-item></swiper><image wx:else src="{{d}}" mode="aspectFill" class="single-img data-v-acf502d9"></image><view class="info-card data-v-acf502d9"><view class="price-line data-v-acf502d9"><text class="price-symbol data-v-acf502d9">¥</text><text class="price-value data-v-acf502d9">{{e}}</text><text wx:if="{{f}}" class="price-old data-v-acf502d9">¥{{g}}</text></view><text class="product-title data-v-acf502d9">{{h}}</text><text wx:if="{{i}}" class="product-subtitle data-v-acf502d9">{{j}}</text><view class="meta-line data-v-acf502d9"><text class="data-v-acf502d9">销量 {{k}}</text><text class="data-v-acf502d9">库存 {{l}}</text><text wx:if="{{m}}" class="data-v-acf502d9">/{{n}}</text></view><view wx:if="{{o}}" class="tags data-v-acf502d9"><text class="tag data-v-acf502d9">{{p}}</text><text wx:if="{{q}}" class="tag data-v-acf502d9">保质期{{r}}天</text></view></view><view wx:if="{{s}}" class="sku-card data-v-acf502d9"><text class="card-title data-v-acf502d9">规格选择</text><view class="sku-list data-v-acf502d9"><view wx:for="{{t}}" wx:for-item="sku" wx:key="e" class="{{['data-v-acf502d9', 'sku-item', sku.f]}}" bindtap="{{sku.g}}"><text class="data-v-acf502d9">{{sku.a}}{{sku.b}}</text><text wx:if="{{sku.c}}" class="data-v-acf502d9"> ¥{{sku.d}}</text></view></view></view><view wx:if="{{v}}" class="detail-card data-v-acf502d9"><text class="card-title data-v-acf502d9">商品详情</text><rich-text class="data-v-acf502d9" nodes="{{w}}"></rich-text></view><view class="review-card data-v-acf502d9"><text class="card-title data-v-acf502d9">用户评价 ({{x}})</text><view wx:if="{{y}}" class="empty-tip data-v-acf502d9">暂无评价</view><view wx:for="{{z}}" wx:for-item="rv" wx:key="f" class="review-item data-v-acf502d9"><vi