}
.item-img.data-v-c10c040c {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.item-info.data-v-c10c040c {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.item-name.data-v-c10c040c {
